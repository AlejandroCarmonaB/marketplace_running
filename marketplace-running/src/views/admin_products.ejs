<%- include('partials/header') %>

<section class="page-title">
  <h2>Gestión de productos</h2>
  <p>Administra el estado de publicaciones y programa bajas lógicas sin perder tu posición en la página.</p>
</section>

<% if (mensajeExito) { %>
  <div class="mensaje-exito"><p><%= mensajeExito %></p></div>
<% } %>

<% if (mensajeError) { %>
  <div class="mensaje-error"><p><%= mensajeError %></p></div>
<% } %>

<section class="form-container">
  <form method="GET" action="/admin/productos" class="formulario">
    <div class="form-group">
      <label for="q">Buscar por título o vendedor</label>
      <input type="text" id="q" name="q" value="<%= termino %>" placeholder="Introduce título o nickname">
    </div>

    <div class="form-group">
      <label for="estado">Filtrar por estado</label>
      <select id="estado" name="estado">
        <option value="" <%= !estado ? 'selected' : '' %>>Todos</option>
        <option value="activo" <%= estado === 'activo' ? 'selected' : '' %>>Activo</option>
        <option value="inactivo" <%= estado === 'inactivo' ? 'selected' : '' %>>Inactivo</option>
        <option value="rechazado" <%= estado === 'rechazado' ? 'selected' : '' %>>Rechazado</option>
        <option value="vendido" <%= estado === 'vendido' ? 'selected' : '' %>>Vendido</option>
      </select>
    </div>

    <button type="submit" class="btn-principal">Aplicar filtros</button>
  </form>
</section>

<% if (productos.length === 0) { %>
  <p class="no-products">No se han encontrado productos con esos criterios.</p>
<% } else { %>
  <div class="productos-grid" id="lista-productos-admin">
    <% productos.forEach(producto => { %>
      <div class="producto-card js-producto-card" data-producto-id="<%= producto.id_prod %>">
        <% if (producto.imagen_principal) { %>
          <img 
            src="<%= producto.imagen_principal.startsWith('http') ? producto.imagen_principal : '/' + producto.imagen_principal %>"
            alt="Imagen del producto"
            class="producto-imagen"
          >
        <% } else { %>
          <div class="producto-imagen-placeholder">Sin imagen</div>
        <% } %>

        <div class="producto-info">
          <h3 class="producto-titulo"><%= producto.titulo %></h3>
          <p><strong>Vendedor:</strong> <%= producto.vendedor %></p>
          <p><strong>Precio:</strong> <%= Number(producto.precio).toFixed(2) %> €</p>
          <p><strong>Estado físico:</strong> <%= producto.estado_fisico %></p>
          <p>
            <strong>Estado publicación:</strong>
            <span class="js-estado-publicacion"><%= producto.estado_publicacion %></span>
          </p>

          <div class="producto-acciones">
            <% if (producto.estado_publicacion !== 'vendido') { %>
              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST" class="js-form-estado-producto-admin">
                <input type="hidden" name="nuevoEstado" value="activo">
                <button type="submit" class="btn-principal">Activar</button>
              </form>

              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST" class="js-form-estado-producto-admin">
                <input type="hidden" name="nuevoEstado" value="inactivo">
                <button type="submit" class="btn-secundario">Inactivar</button>
              </form>

              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST" class="js-form-estado-producto-admin">
                <input type="hidden" name="nuevoEstado" value="rechazado">
                <button type="submit" class="btn-peligro">Rechazar</button>
              </form>
            <% } %>

            <form action="/admin/productos/<%= producto.id_prod %>/programar-baja" method="POST" class="js-form-baja-producto-admin">
              <input type="hidden" name="motivo" value="Baja administrativa desde panel admin">
              <button type="submit" class="btn-peligro">Programar baja</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<script>
  function mostrarToastDinamico(mensaje, tipo = 'exito') {
    const toast = document.createElement('div');
    toast.className = tipo === 'error' ? 'toast-error' : 'toast-exito';
    toast.textContent = mensaje;
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(-10px)';
      setTimeout(() => toast.remove(), 300);
    }, 2500);
  }

  async function enviarFormularioAjax(form) {
    const response = await fetch(form.action, {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Accept': 'application/json',
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams(new FormData(form))
    });

    const data = await response.json();
    if (!response.ok || !data.ok) {
      throw new Error(data.mensaje || 'Ha ocurrido un error.');
    }

    return data;
  }

  document.querySelectorAll('.js-form-estado-producto-admin').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      try {
        const data = await enviarFormularioAjax(form);
        const card = form.closest('.js-producto-card');
        const estadoEl = card.querySelector('.js-estado-publicacion');

        if (estadoEl && data.nuevoEstado) {
          estadoEl.textContent = data.nuevoEstado;
        }

        mostrarToastDinamico(data.mensaje || 'Estado del producto actualizado.');
      } catch (error) {
        mostrarToastDinamico(error.message, 'error');
      }
    });
  });

  document.querySelectorAll('.js-form-baja-producto-admin').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!confirm('¿Seguro que quieres programar la baja de este producto?')) {
        return;
      }

      try {
        const data = await enviarFormularioAjax(form);
        const card = form.closest('.js-producto-card');

        if (data.accion === 'eliminar_tarjeta' && card) {
          card.remove();
        }

        mostrarToastDinamico(data.mensaje || 'Baja lógica del producto programada correctamente.');
      } catch (error) {
        mostrarToastDinamico(error.message, 'error');
      }
    });
  });
</script>

<%- include('partials/footer') %>