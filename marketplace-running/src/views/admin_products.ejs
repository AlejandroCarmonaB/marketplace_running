<%- include('partials/header') %>

<section class="page-title">
  <h2>Gestión de productos</h2>
  <p>Consulta, filtra, cambia estados y programa bajas lógicas de productos.</p>
</section>

<% if (mensajeExito) { %>
  <div class="mensaje-exito"><p><%= mensajeExito %></p></div>
<% } %>

<% if (mensajeError) { %>
  <div class="mensaje-error"><p><%= mensajeError %></p></div>
<% } %>

<section class="form-container">
  <form method="GET" action="/admin/productos" class="formulario">
    <div class="form-group">
      <label for="q">Buscar por título o vendedor</label>
      <input type="text" id="q" name="q" value="<%= termino %>" placeholder="Introduce título o nickname">
    </div>

    <div class="form-group">
      <label for="estado">Filtrar por estado</label>
      <select id="estado" name="estado">
        <option value="" <%= !estado ? 'selected' : '' %>>Todos</option>
        <option value="activo" <%= estado === 'activo' ? 'selected' : '' %>>Activo</option>
        <option value="inactivo" <%= estado === 'inactivo' ? 'selected' : '' %>>Inactivo</option>
        <option value="rechazado" <%= estado === 'rechazado' ? 'selected' : '' %>>Rechazado</option>
        <option value="vendido" <%= estado === 'vendido' ? 'selected' : '' %>>Vendido</option>
      </select>
    </div>

    <button type="submit" class="btn-principal">Aplicar filtros</button>
  </form>
</section>

<% if (productos.length === 0) { %>
  <p class="no-products">No se han encontrado productos con esos criterios.</p>
<% } else { %>
  <div class="productos-grid">
    <% productos.forEach(producto => { %>
      <div class="producto-card">
        <% if (producto.imagen_principal) { %>
          <img 
            src="<%= producto.imagen_principal.startsWith('http') ? producto.imagen_principal : '/' + producto.imagen_principal %>"
            alt="Imagen del producto"
            class="producto-imagen"
          >
        <% } else { %>
          <div class="producto-imagen-placeholder">Sin imagen</div>
        <% } %>

        <div class="producto-info">
          <h3 class="producto-titulo"><%= producto.titulo %></h3>
          <p><strong>Vendedor:</strong> <%= producto.vendedor %></p>
          <p><strong>Precio:</strong> <%= Number(producto.precio).toFixed(2) %> €</p>
          <p><strong>Estado publicación:</strong> <%= producto.estado_publicacion %></p>
          <p><strong>Estado físico:</strong> <%= producto.estado_fisico %></p>

          <div class="producto-acciones">
            <% if (producto.estado_publicacion !== 'vendido') { %>
              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST">
                <input type="hidden" name="nuevoEstado" value="rechazado">
                <button type="submit" class="btn-secundario">Rechazar</button>
              </form>

              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST">
                <input type="hidden" name="nuevoEstado" value="inactivo">
                <button type="submit" class="btn-secundario">Inactivar</button>
              </form>

              <form action="/admin/productos/<%= producto.id_prod %>/estado" method="POST">
                <input type="hidden" name="nuevoEstado" value="activo">
                <button type="submit" class="btn-principal">Activar</button>
              </form>
            <% } %>

            <form action="/admin/productos/<%= producto.id_prod %>/programar-baja" method="POST">
              <input type="hidden" name="motivo" value="Baja administrativa desde panel admin">
              <button type="submit" class="btn-peligro">Programar baja</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>