<%- include('partials/header') %>

<section class="page-title">
  <h2>Tu carrito</h2>
  <p>Revisa los productos antes de finalizar la compra</p>
</section>

<% if (carrito.length === 0) { %>
  <div class="no-products">
    <p>Tu carrito está vacío.</p>

    <div class="carrito-vacio-acciones">
      <a href="/" class="btn-secundario">Ver productos</a>
    </div>
  </div>

<% } else { %>

  <section class="form-container">

    <div class="productos-grid">
      <% carrito.forEach(item => { %>
        <div class="producto-card">
          <div class="producto-info">
            <h3><%= item.titulo %></h3>

            <p><strong>Precio:</strong> <%= Number(item.precio).toFixed(2) %> €</p>
            <p><strong>Cantidad:</strong> <%= item.cantidad || 1 %></p>

            <form action="/carrito/eliminar/<%= item.id_prod %>" method="POST">
              <button class="btn-peligro" type="submit">
                Eliminar
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="carrito-resumen">
      <p>
        <span>Total del carrito</span>
        <strong><%= Number(total).toFixed(2) %> €</strong>
      </p>
    </div>

    <div class="carrito-acciones">
      <a href="/" class="btn-secundario">
        ← Continuar comprando
      </a>

      <form action="/carrito/vaciar" method="POST" onsubmit="return confirm('¿Seguro que quieres vaciar todo el carrito?');">
        <button type="submit" class="btn-secundario">
          Vaciar carrito
        </button>
      </form>

      <form action="/carrito/comprar" method="POST">
        <button type="submit" class="btn-principal">
          Finalizar compra
        </button>
      </form>
    </div>

  </section>

<% } %>

<%- include('partials/footer') %>