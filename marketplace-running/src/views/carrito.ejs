<%- include('partials/header') %>

<section class="page-title">
  <h2>Carrito</h2>
  <p>Revisa los productos añadidos antes de completar la compra.</p>
</section>

<% if (mensajeError) { %>
  <div class="mensaje-error" id="mensaje-error">
    <p><%= mensajeError %></p>
  </div>
<% } %>

<% if (carrito.length === 0) { %>

  <p class="no-products">
    Tu carrito está vacío.
  </p>

<% } else { %>

  <div class="productos-grid">

    <% carrito.forEach(producto => { %>
      <div class="producto-card">

        <div class="producto-info">
          <h3 class="producto-titulo">
            <a href="/producto/<%= producto.id_prod %>">
              <%= producto.titulo %>
            </a>
          </h3>

          <p class="producto-descripcion">
            <%= producto.descripcion %>
          </p>

          <p class="producto-precio">
            <strong>Precio:</strong> <%= producto.precio %> €
          </p>

          <p class="producto-categoria">
            <strong>Categoría:</strong> <%= producto.nombre_categoria %>
          </p>

          <p class="producto-vendedor">
            <strong>Vendedor:</strong> <%= producto.vendedor %>
          </p>

          <form action="/carrito/eliminar/<%= producto.id_prod %>" method="POST">
            <button type="submit" class="btn-principal">Eliminar</button>
          </form>
        </div>

      </div>
    <% }) %>

  </div>

  <section class="form-container">
    <p><strong>Total:</strong> <%= total.toFixed(2) %> €</p>

    <form action="/carrito/comprar" method="POST">
      <button type="submit" class="btn-principal">Comprar</button>
    </form>
  </section>

<% } %>

<%- include('partials/footer') %>