<%- include('partials/header') %>

<section class="page-title">
  <h2>Mis productos</h2>
  <p>Listado de productos publicados por el usuario actual.</p>
</section>

<% if (mensajeExito) { %>
  <div class="mensaje-exito" id="mensaje-exito">
    <p><%= mensajeExito %></p>
  </div>

  <script>
    setTimeout(() => {
      const mensaje = document.getElementById('mensaje-exito');
      if (mensaje) {
        mensaje.style.transition = 'opacity 0.5s ease';
        mensaje.style.opacity = '0';

        setTimeout(() => {
          mensaje.style.display = 'none';
        }, 500);
      }
    }, 3000);
  </script>
<% } %>

<% if (productos.length === 0) { %>

  <p class="no-products">
    Todavía no has publicado ningún producto.
  </p>

  <a href="/publicar-producto" class="btn-principal">
    Publicar mi primer producto
  </a>

<% } else { %>

  <div class="productos-grid">

    <% productos.forEach(producto => { %>

      <div class="producto-card">

        <% if (producto.imagen_principal) { %>
          <img 
            src="<%= producto.imagen_principal.startsWith('http') ? producto.imagen_principal : '/' + producto.imagen_principal %>"
            alt="Imagen de <%= producto.titulo %>"
            class="producto-imagen"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          >
          <div class="producto-imagen-placeholder" style="display: none;">
            Sin imagen
          </div>
        <% } else { %>
          <div class="producto-imagen-placeholder">
            Sin imagen
          </div>
        <% } %>

        <div class="producto-info">
          <h3 class="producto-titulo">
            <a href="/producto/<%= producto.id_prod %>">
              <%= producto.titulo %>
            </a>
          </h3>

          <p class="producto-descripcion">
            <%= producto.descripcion %>
          </p>

          <p class="producto-precio">
            <strong>Precio:</strong> <%= producto.precio %> €
          </p>

          <p class="producto-categoria">
            <strong>Categoría:</strong> <%= producto.nombre_categoria %>
          </p>

          <p class="producto-estado">
            <strong>Estado físico:</strong> <%= producto.estado_fisico %>
          </p>

          <p class="producto-stock">
            <strong>Stock:</strong> <%= producto.stock %>
          </p>

          <p class="producto-publicacion">
            <strong>Estado de publicación:</strong> <%= producto.estado_publicacion %>
          </p>

          <% if (producto.estado_publicacion !== 'vendido') { %>
            <div class="producto-acciones">
              <a href="/editar-producto/<%= producto.id_prod %>" class="btn-principal">
                Editar
              </a>

              <form action="/eliminar-producto/<%= producto.id_prod %>" method="POST" style="display:inline;">
                <button 
                  type="submit" 
                  class="btn-principal"
                  onclick="return confirm('¿Seguro que quieres desactivar este producto?');"
                >
                  Eliminar
                </button>
              </form>
            </div>
          <% } %>
        </div>

      </div>

    <% }) %>

  </div>

<% } %>

<%- include('partials/footer') %>