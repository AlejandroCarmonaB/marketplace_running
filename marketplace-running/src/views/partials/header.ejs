<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marketplace Running</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="rol-<%= usuarioSesion ? usuarioSesion.nombre_rol : 'invitado' %>">
  <header class="site-header">
    <div class="site-header-inner">
      <div class="site-brand">
        <a href="/" class="site-brand-link">
          <span class="site-brand-mark">MR</span>
          <div class="site-brand-text">
            <h1>Marketplace Running</h1>
            <p>Segunda mano especializada en running</p>
          </div>
        </a>
      </div>

      <nav class="site-nav" id="siteNav">
        <a href="/" class="nav-link">Catálogo</a>

        <% if (usuarioSesion) { %>

          <% if (usuarioSesion.nombre_rol === 'usuario') { %>
            <a href="/carrito" class="nav-link nav-carrito">
              Carrito
              <% if (carritoCount > 0) { %>
                <span class="carrito-badge"><%= carritoCount %></span>
              <% } %>
            </a>
            <a href="/mis-pedidos" class="nav-link">Mis pedidos</a>
            <a href="/mis-productos" class="nav-link">Mis productos</a>
            <a href="/publicar-producto" class="nav-link nav-link-accent">Publicar producto</a>

          <% } else if (usuarioSesion.nombre_rol === 'administrador') { %>
            <a href="/verificaciones" class="nav-link">Verificaciones</a>
            <a href="/admin/usuarios" class="nav-link">Usuarios</a>
            <a href="/admin/productos" class="nav-link nav-link-accent">Gestión productos</a>
            <a href="/analitica" class="nav-link">Analítica</a>

          <% } else if (usuarioSesion.nombre_rol === 'verificador') { %>
            <a href="/verificaciones" class="nav-link nav-link-accent">Verificaciones</a>

          <% } else if (usuarioSesion.nombre_rol === 'analista') { %>
            <a href="/analitica" class="nav-link nav-link-accent">Analítica</a>

          <% } else if (usuarioSesion.nombre_rol === 'superadministrador') { %>
            <a href="/verificaciones" class="nav-link">Verificaciones</a>
            <a href="/admin/usuarios" class="nav-link">Usuarios</a>
            <a href="/admin/productos" class="nav-link">Gestión productos</a>
            <a href="/analitica" class="nav-link">Analítica</a>
            <a href="/superadmin" class="nav-link nav-link-accent">Auditoría</a>
          <% } %>

        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="nav-link nav-link-accent">Registro</a>
        <% } %>
      </nav>

      <% if (usuarioSesion) { %>
        <div class="site-user-box" id="userBox">
          <div class="site-user-meta">
            <span class="site-user-greeting">Hola, <%= usuarioSesion.nickname %></span>
            <span class="site-user-role"><%= usuarioSesion.nombre_rol %></span>
          </div>
          <a href="/logout" class="site-user-logout">Cerrar sesión</a>
        </div>
      <% } %>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <script>
    const navToggle = document.getElementById('navToggle');
    const siteNav = document.getElementById('siteNav');
    const userBox = document.getElementById('userBox');

    navToggle.addEventListener('click', () => {
      siteNav.classList.toggle('nav-abierto');
      if (userBox) userBox.classList.toggle('nav-abierto');
    });
  </script>

  <% if (mensajeToast) { %>
    <div class="toast-exito" id="toastExito">
      <%= mensajeToast %>
    </div>

    <script>
      setTimeout(() => {
        const toast = document.getElementById("toastExito");
        if (toast) {
          toast.style.opacity = "0";
          toast.style.transform = "translateY(-10px)";
        }
      }, 3000);
    </script>
  <% } %>

  <main class="site-main">