<%- include('partials/header') %>

<section class="page-title">
  <h2>Detalle del producto</h2>
</section>

<%
  const esUsuarioNormal = usuarioSesion && usuarioSesion.nombre_rol === 'usuario';
%>

<% if (mensajeExito) { %>
  <div class="mensaje-exito" id="mensaje-exito">
    <p><%= mensajeExito %></p>
  </div>
  <script>
    setTimeout(() => {
      const mensaje = document.getElementById('mensaje-exito');
      if (mensaje) {
        mensaje.style.transition = 'opacity 0.5s ease';
        mensaje.style.opacity = '0';
        setTimeout(() => {
          mensaje.style.display = 'none';
        }, 500);
      }
    }, 3000);
  </script>
<% } %>

<% if (mensajeError) { %>
  <div class="mensaje-error" id="mensaje-error">
    <p><%= mensajeError %></p>
  </div>
<% } %>

<section class="form-container">
  <div class="producto-card">
    <div class="producto-info">

      <% if (imagenes && imagenes.length > 0) { %>
        <div class="galeria-producto">
          <div class="galeria-principal">
            <img
              id="imagenPrincipalProducto"
              src="<%= imagenes[0].url_imagen.startsWith('http') ? imagenes[0].url_imagen : '/' + imagenes[0].url_imagen %>"
              alt="Imagen principal del producto"
              class="producto-imagen producto-imagen-detalle"
            >
          </div>

          <% if (imagenes.length > 1) { %>
            <div class="galeria-miniaturas">
              <% imagenes.forEach((imagen, index) => { %>
                <button
                  type="button"
                  class="miniatura-btn <%= index === 0 ? 'activa' : '' %>"
                  onclick="cambiarImagenPrincipal(this, '<%= imagen.url_imagen.startsWith('http') ? imagen.url_imagen : '/' + imagen.url_imagen %>')"
                >
                  <img
                    src="<%= imagen.url_imagen.startsWith('http') ? imagen.url_imagen : '/' + imagen.url_imagen %>"
                    alt="Miniatura <%= index + 1 %>"
                    class="miniatura-img"
                  >
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      <% } else if (producto.imagen_principal) { %>
        <img 
          src="<%= producto.imagen_principal.startsWith('http') ? producto.imagen_principal : '/' + producto.imagen_principal %>"
          alt="Imagen del producto"
          class="producto-imagen producto-imagen-detalle"
        >
      <% } else { %>
        <div class="producto-imagen-placeholder">Sin imagen</div>
      <% } %>

      <h3><%= producto.titulo %></h3>
      <p><strong>Descripción:</strong> <%= producto.descripcion %></p>
      <p><strong>Precio:</strong> <%= Number(producto.precio).toFixed(2) %> €</p>
      <p><strong>Estado:</strong> <%= producto.estado_fisico %></p>

      <p>
        <strong>Vendedor:</strong> 
        <a href="/vendedor/<%= producto.id_vendedor %>">
          <%= producto.vendedor %>
        </a>
      </p>

      <p><strong>Stock disponible:</strong> <%= producto.stock %></p>

      <% if (esUsuarioNormal && producto.stock > 0 && usuarioSesion.id_usuario !== producto.id_vendedor) { %>
        <form method="POST" action="/carrito/agregar/<%= producto.id_prod %>">
          <button type="submit" class="btn-principal">Añadir al carrito</button>
        </form>
      <% } %>

      <% if (!usuarioSesion) { %>
        <p>Debes iniciar sesión para comprar.</p>
      <% } %>

      <% if (producto.stock <= 0 && producto.estado_publicacion !== 'vendido') { %>
        <p>Producto no disponible.</p>
      <% } %>

      <% if (producto.estado_publicacion === 'vendido') { %>
        <p class="producto-estado-aviso">Este producto no está disponible.</p>
      <% } %>

    </div>
  </div>
</section>

<section class="form-container">
  <h3>Valoraciones del producto</h3>
  <p>Media: <strong><%= resumen.media_valoraciones %></strong> ⭐</p>
  <p>Total reseñas: <%= resumen.total_resenyas %></p>
</section>

<% if (esUsuarioNormal && usuarioSesion.id_usuario !== producto.id_vendedor) { %>
  <section class="form-container">
    <h3><%= resenyaUsuario ? "Editar tu reseña" : "Dejar una reseña" %></h3>

    <form method="POST" action="/producto/<%= producto.id_prod %>/resena" class="formulario">
      <select name="valoracion">
        <% for (let i = 1; i <= 5; i++) { %>
          <option value="<%= i %>" <%= resenyaUsuario && resenyaUsuario.valoracion == i ? "selected" : "" %>>
            <%= i %> ⭐
          </option>
        <% } %>
      </select>

      <textarea name="comentario"><%= resenyaUsuario ? resenyaUsuario.comentario : "" %></textarea>

      <button type="submit" class="btn-principal">
        <%= resenyaUsuario ? "Actualizar reseña" : "Enviar reseña" %>
      </button>
    </form>
  </section>
<% } %>

<section class="form-container">
  <h3>Opiniones de otros usuarios</h3>

  <% if (resenyas.length === 0) { %>
    <p class="no-products">No hay reseñas todavía.</p>
  <% } else { %>
    <% resenyas.forEach(resena => { %>
      <div class="producto-card">
        <div class="producto-info">
          <p><strong><%= resena.autor %></strong></p>
          <p>Valoración: <%= resena.valoracion %> ⭐</p>
          <p><%= resena.comentario %></p>
          <small><%= new Date(resena.fecha_resenya).toISOString().split('T')[0] %></small>
        </div>
      </div>
    <% }) %>
  <% } %>
</section>

<script>
  function cambiarImagenPrincipal(boton, nuevaRuta) {
    const imagenPrincipal = document.getElementById('imagenPrincipalProducto');
    if (imagenPrincipal) {
      imagenPrincipal.src = nuevaRuta;
    }

    document.querySelectorAll('.miniatura-btn').forEach(btn => {
      btn.classList.remove('activa');
    });

    boton.classList.add('activa');
  }
</script>

<%- include('partials/footer') %>