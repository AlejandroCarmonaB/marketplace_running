<%- include('partials/header') %>

<section class="page-title">
  <h2><%= modoEdicion ? 'Editar producto' : 'Publicar producto' %></h2>
</section>

<section class="form-container">

  <% if (error) { %>
    <div class="mensaje-error"><p><%= error %></p></div>
  <% } %>

  <form 
    action="<%= modoEdicion ? '/editar-producto/' + idProducto : '/publicar-producto' %>" 
    method="POST"
    enctype="multipart/form-data"
  >

    <div class="form-group">
      <label for="titulo">Título</label>
      <input 
        type="text" 
        id="titulo" 
        name="titulo" 
        value="<%= datos.titulo || '' %>" 
        required
      >
    </div>

    <div class="form-group">
      <label for="descripcion">Descripción</label>
      <textarea 
        id="descripcion" 
        name="descripcion" 
        required
      ><%= datos.descripcion || '' %></textarea>
    </div>

    <div class="form-group">
      <label for="precio">Precio</label>
      <input 
        type="number" 
        id="precio" 
        name="precio" 
        step="0.01" 
        min="0" 
        value="<%= datos.precio || '' %>" 
        required
      >
    </div>

    <div class="form-group">
      <label for="estado_fisico">Estado físico</label>
      <select id="estado_fisico" name="estado_fisico" required>
        <option value="">Selecciona</option>
        <option value="como nuevo" <%= datos.estado_fisico === 'como nuevo' ? 'selected' : '' %>>Como nuevo</option>
        <option value="excelente estado" <%= datos.estado_fisico === 'excelente estado' ? 'selected' : '' %>>Excelente estado</option>
        <option value="muy poco uso" <%= datos.estado_fisico === 'muy poco uso' ? 'selected' : '' %>>Muy poco uso</option>
        <option value="buen estado" <%= datos.estado_fisico === 'buen estado' ? 'selected' : '' %>>Buen estado</option>
        <option value="uso moderado" <%= datos.estado_fisico === 'uso moderado' ? 'selected' : '' %>>Uso moderado</option>
      </select>
    </div>

    <div class="form-group">
      <label for="id_categoria">Categoría</label>
      <select id="id_categoria" name="id_categoria" required>
        <option value="">Selecciona</option>
        <% categorias.forEach(cat => { %>
          <option 
            value="<%= cat.id_categoria %>"
            <%= String(datos.id_categoria) === String(cat.id_categoria) ? 'selected' : '' %>
          >
            <%= cat.nombre_categoria %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="imagenes">Imágenes del producto</label>

      <div id="zona-drop" class="zona-drop">
        <p>Arrastra aquí tus imágenes o pulsa para seleccionarlas</p>
        <input 
          type="file" 
          id="imagenes" 
          name="imagenes" 
          multiple 
          accept="image/jpeg,image/png,image/webp"
          style="display: none;"
        >
        <button type="button" id="btn-seleccionar-imagenes" class="btn-principal">
          Seleccionar imágenes
        </button>
      </div>

      <small>Máximo 5 imágenes. Formatos permitidos: JPG, PNG y WEBP.</small>

      <div id="preview-imagenes" class="preview-imagenes"></div>
    </div>

    <button type="submit" class="btn-principal">
      <%= modoEdicion ? 'Guardar cambios' : 'Publicar producto' %>
    </button>

  </form>

</section>

<script>
  const inputImagenes = document.getElementById('imagenes');
  const previewImagenes = document.getElementById('preview-imagenes');
  const zonaDrop = document.getElementById('zona-drop');
  const btnSeleccionar = document.getElementById('btn-seleccionar-imagenes');

  btnSeleccionar.addEventListener('click', () => {
    inputImagenes.click();
  });

  zonaDrop.addEventListener('click', (event) => {
    if (event.target !== btnSeleccionar) {
      inputImagenes.click();
    }
  });

  inputImagenes.addEventListener('change', actualizarPreview);

  zonaDrop.addEventListener('dragover', (event) => {
    event.preventDefault();
    zonaDrop.classList.add('zona-drop-activa');
  });

  zonaDrop.addEventListener('dragleave', () => {
    zonaDrop.classList.remove('zona-drop-activa');
  });

  zonaDrop.addEventListener('drop', (event) => {
    event.preventDefault();
    zonaDrop.classList.remove('zona-drop-activa');

    const archivos = Array.from(event.dataTransfer.files).filter(file =>
      ['image/jpeg', 'image/png', 'image/webp'].includes(file.type)
    );

    const dataTransfer = new DataTransfer();

    archivos.slice(0, 5).forEach(file => dataTransfer.items.add(file));
    inputImagenes.files = dataTransfer.files;

    actualizarPreview();
  });

  function actualizarPreview() {
    previewImagenes.innerHTML = '';

    const archivos = Array.from(inputImagenes.files);

    archivos.slice(0, 5).forEach(file => {
      const lector = new FileReader();

      lector.onload = function (event) {
        const contenedor = document.createElement('div');
        contenedor.className = 'preview-item';

        const img = document.createElement('img');
        img.src = event.target.result;
        img.alt = file.name;
        img.className = 'preview-img';

        contenedor.appendChild(img);
        previewImagenes.appendChild(contenedor);
      };

      lector.readAsDataURL(file);
    });
  }
</script>

<%- include('partials/footer') %>