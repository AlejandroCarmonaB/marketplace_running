<%- include('partials/header') %>

<section class="page-title">
  <h2>Listado de productos</h2>
  <p>Catálogo de productos de running disponibles en la plataforma.</p>
</section>

<form method="GET" action="/" class="form-busqueda">
  <input 
    type="text" 
    name="q" 
    placeholder="Buscar productos..."
    value="<%= termino || '' %>"
  >

  <select name="categoria">
    <option value="">Todas las categorías</option>
    <% categorias.forEach(cat => { %>
      <option 
        value="<%= cat.id_categoria %>"
        <%= String(filtros?.idCategoria || '') === String(cat.id_categoria) ? 'selected' : '' %>
      >
        <%= cat.nombre_categoria %>
      </option>
    <% }) %>
  </select>

  <input 
    type="number" 
    name="precioMax" 
    placeholder="Precio máximo"
    min="0"
    step="0.01"
    value="<%= filtros?.precioMax || '' %>"
  >

  <button type="submit">Filtrar</button>
</form>

<% if (productos.length === 0) { %>

  <p class="no-products">
    No hay productos disponibles en este momento.
  </p>

<% } else { %>

  <div class="productos-grid">

    <% productos.forEach(producto => { %>

      <div class="producto-card">

        <% if (producto.imagen_principal) { %>
          <img 
            src="<%= producto.imagen_principal.startsWith('http') ? producto.imagen_principal : '/' + producto.imagen_principal %>"
            alt="Imagen de <%= producto.titulo %>"
            class="producto-imagen"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          >
          <div class="producto-imagen-placeholder" style="display: none;">
            Sin imagen
          </div>
        <% } else { %>
          <div class="producto-imagen-placeholder">
            Sin imagen
          </div>
        <% } %>

        <div class="producto-info">
          <h3 class="producto-titulo">
            <a href="/producto/<%= producto.id_prod %>">
              <%= producto.titulo %>
            </a>
          </h3>

          <p class="producto-descripcion">
            <%= producto.descripcion %>
          </p>

          <p class="producto-precio">
            <strong>Precio:</strong> <%= producto.precio %> €
          </p>

          <p class="producto-categoria">
            <strong>Categoría:</strong> <%= producto.nombre_categoria %>
          </p>

          <p class="producto-estado">
            <strong>Estado físico:</strong> <%= producto.estado_fisico %>
          </p>

          <p class="producto-stock">
            <strong>Stock:</strong> <%= producto.stock %>
          </p>

          <p class="producto-vendedor">
            <strong>Vendedor:</strong> <%= producto.vendedor %>
          </p>

          <div class="producto-acciones">
            <a href="/producto/<%= producto.id_prod %>" class="btn-secundario">Ver detalle</a>

            <% if (
              usuarioSesion &&
              usuarioSesion.nombre_rol === 'usuario' &&
              usuarioSesion.id_usuario !== producto.id_vendedor &&
              producto.stock > 0 &&
              producto.estado_publicacion !== 'vendido'
            ) { %>
              <% if (idsEnCarrito && idsEnCarrito.includes(producto.id_prod)) { %>
                <span class="producto-en-carrito">Ya está en tu carrito</span>
              <% } else { %>
                <form method="POST" action="/carrito/agregar/<%= producto.id_prod %>">
                  <button type="submit" class="btn-principal">Añadir al carrito</button>
                </form>
              <% } %>
            <% } %>
          </div>
        </div>

      </div>

    <% }) %>

  </div>

<% } %>

<%- include('partials/footer') %>