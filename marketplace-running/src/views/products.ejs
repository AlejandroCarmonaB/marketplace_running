<%- include('partials/header') %>

<section class="page-title">
  <h2>Listado de productos</h2>
  <p>Catálogo de productos de running disponibles en la plataforma.</p>
</section>

<% if (productos.length === 0) { %>

  <p class="no-products">
    No hay productos disponibles en este momento.
  </p>

<% } else { %>

  <div class="productos-grid">

    <% productos.forEach(producto => { %>

      <div class="producto-card">

        <% if (producto.imagen_principal) { %>
          <img 
            src="/<%= producto.imagen_principal %>"
            alt="Imagen de <%= producto.titulo %>"
            class="producto-imagen"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          >
          <div class="producto-imagen-placeholder" style="display: none;">
            Sin imagen
          </div>
        <% } else { %>
          <div class="producto-imagen-placeholder">
            Sin imagen
          </div>
        <% } %>

        <div class="producto-info">
          <h3 class="producto-titulo">
            <a href="/producto/<%= producto.id_prod %>">
              <%= producto.titulo %>
            </a>
          </h3>

          <p class="producto-descripcion">
            <%= producto.descripcion %>
          </p>

          <p class="producto-precio">
            <strong>Precio:</strong> <%= producto.precio %> €
          </p>

          <p class="producto-categoria">
            <strong>Categoría:</strong> <%= producto.nombre_categoria %>
          </p>

          <p class="producto-estado">
            <strong>Estado físico:</strong> <%= producto.estado_fisico %>
          </p>

          <p class="producto-stock">
            <strong>Stock:</strong> <%= producto.stock %>
          </p>

          <p class="producto-vendedor">
            <strong>Vendedor:</strong> <%= producto.vendedor %>
          </p>
        </div>

      </div>

    <% }) %>

  </div>

<% } %>

<%- include('partials/footer') %>