<%- include('partials/header') %>

<section class="page-title">
  <h2>Perfil de <%= vendedor.nickname %></h2>
</section>

<section class="form-container">
  <h3>Valoraciones</h3>
  <p>Media: <strong><%= resumen.media_valoraciones %></strong> ⭐</p>
</section>

<%
  const esUsuarioNormal = usuarioSesion && usuarioSesion.nombre_rol === 'usuario';
%>

<% if (esUsuarioNormal && usuarioSesion.id_usuario !== vendedor.id_usuario) { %>
  <section class="form-container">
    <form method="POST" action="/vendedor/<%= vendedor.id_usuario %>/resena">
      <select name="valoracion">
        <% for (let i = 1; i <= 5; i++) { %>
          <option value="<%= i %>"><%= i %> ⭐</option>
        <% } %>
      </select>

      <textarea name="comentario"></textarea>

      <button class="btn-principal">Enviar reseña</button>
    </form>
  </section>
<% } %>

<section class="form-container">
  <% resenyas.forEach(r => { %>
    <div class="producto-card">
      <p><%= r.autor %></p>
      <p><%= r.valoracion %> ⭐</p>
      <p><%= r.comentario %></p>
    </div>
  <% }) %>
</section>

<%- include('partials/footer') %>